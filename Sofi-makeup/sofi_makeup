  <!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tienda</title>

<style>
body{
margin:0;
font-family:'Segoe UI',sans-serif;
background:linear-gradient(135deg,#fff0f6,#ffe4ec,#fff5f9);
}

/* 🔍 BUSCADOR */
.buscador{
position:fixed;
top:15px;
right:15px;
z-index:9999;
}
.buscador button{
background:white;
border:none;
border-radius:50%;
width:35px;
height:35px;
font-size:16px;
cursor:pointer;
box-shadow:0 5px 15px rgba(0,0,0,0.2);
}
.buscador input{
display:none;
position:absolute;
top:45px;
right:0;
padding:6px 12px;
border-radius:20px;
border:2px solid #ff69b4;
outline:none;
}

/* PORTADA */
.hero{
position:relative;
height:90vh;
overflow:hidden;
}
.slide{
position:absolute;
width:100%;
height:100%;
background-size:cover;
background-position:center;
opacity:0;
transition:opacity 1.5s ease;
}
.slide.active{opacity:1;}
.hero button{
position:absolute;
bottom:60px;
left:50%;
transform:translateX(-50%);
padding:15px 40px;
border:none;
border-radius:30px;
background:#ff69b4;
color:white;
font-size:18px;
cursor:pointer;
}

/* CATEGORIAS */
.categorias{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:35px;
padding:50px 20px;
}
.categoria{
text-align:center;
cursor:pointer;
}
.categoria img{
width:120px;
height:120px;
border-radius:50%;
object-fit:cover;
border:4px solid #ff69b4;
transition:0.3s;
}
.categoria img:hover{transform:scale(1.1);}
.categoria p{
font-weight:bold;
text-transform:uppercase;
}

/* PRODUCTOS */
.productos{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:30px;
padding:40px;
}
.producto{
width:260px;
background:white;
padding:20px;
border-radius:25px;
box-shadow:0 15px 35px rgba(0,0,0,0.08);
text-align:center;
}
.producto img{
width:100%;
border-radius:15px;
}
.producto button{
margin-top:10px;
padding:8px 15px;
border:none;
border-radius:20px;
background:#ff69b4;
color:white;
cursor:pointer;
}

/* CARRITO */
.carrito-btn{
position:fixed;
bottom:20px;
right:20px;
background:#ff1493;
color:white;
border:none;
border-radius:50px;
padding:15px;
cursor:pointer;
}
.carrito-modal{
display:none;
position:fixed;
top:50%;
left:50%;
transform:translate(-50%,-50%);
background:white;
padding:25px;
border-radius:20px;
box-shadow:0 20px 50px rgba(0,0,0,0.4);
width:90%;
max-width:400px;
z-index:1000;
}

/* PANEL ADMIN */
.admin-panel{
position:fixed;
top:0;
left:-350px;
width:350px;
height:100%;
background:#ffffff;
box-shadow:5px 0 25px rgba(0,0,0,0.2);
transition:0.4s;
z-index:2000;
display:flex;
flex-direction:column;
}
.admin-panel.active{left:0;}
.admin-header{
padding:20px;
background:#ff69b4;
color:white;
font-weight:bold;
}
.admin-content{
flex:1;
overflow-y:auto;
padding:15px;
}
.admin-content input, .admin-content select{
width:100%;
margin-bottom:10px;
padding:8px;
border-radius:8px;
border:1px solid #ccc;
}
.admin-content button{
width:100%;
margin-bottom:10px;
padding:8px;
border:none;
border-radius:8px;
background:#ff69b4;
color:white;
cursor:pointer;
}
.admin-product{
background:#f8f8f8;
padding:8px;
border-radius:8px;
margin-bottom:8px;
font-size:13px;
}
.admin-product img{
margin-bottom:5px;
}
</style>
</head>
<body>

<div class="buscador">
<button onclick="toggleBuscador()">🔎</button>
<input type="text" id="buscadorInput" placeholder="Buscar producto..." onkeyup="buscarProductos()">
</div>

<section class="hero">
<div class="slide active" style="background-image:url('SOFI__MAKEUP.jpeg')"></div>
<div class="slide" style="background-image:url('SOFI__MAKEUP.jpeg')"></div>
<button onclick="document.getElementById('categorias').scrollIntoView({behavior:'smooth'})">
Comprar Ahora
</button>
</section>

<section class="categorias" id="categorias"></section>
<section class="productos" id="productos"></section>

<button class="carrito-btn" onclick="abrirCarrito()">
🛒 <span id="contador">0</span>
</button>

<div class="carrito-modal" id="carritoModal">
<h3>Tu Carrito</h3>
<div id="listaCarrito"></div>
<button onclick="enviarWhatsApp()">Enviar por WhatsApp</button>
<button onclick="cerrarCarrito()">Cerrar</button>
</div>

<div class="admin-panel" id="adminPanel">
<div class="admin-header">Panel Administrador</div>
<div class="admin-content">

<h4>Agregar Producto</h4>
<input type="text" id="nombreProducto" placeholder="Nombre producto">
<button onclick="subirImagen()">Subir Imagen</button>
<select id="categoriaProducto"></select>
<button onclick="guardarProducto()">Guardar Producto</button>

<h4>Agregar Categoría</h4>
<input type="text" id="nuevaCategoriaNombre" placeholder="Nombre categoría">
<button onclick="subirImagenCategoria()">Subir Imagen Categoría</button>
<button onclick="agregarCategoria()">Guardar Categoría</button>

<h4>Editar Categorías</h4>
<div id="listaAdminCategorias"></div>

<h4>Productos</h4>
<div id="listaAdminProductos"></div>

<button onclick="cerrarAdmin()">Cerrar</button>
</div>
</div>

<script src="https://upload-widget.cloudinary.com/global/all.js"></script>

<script>

const cloudName = "sofi-makeup";
const uploadPreset = "sofi_unsigned";
let imagenTemporal="";
let imagenCategoriaTemporal="";

let productos=JSON.parse(localStorage.getItem("productos"))||[];
let carrito=JSON.parse(localStorage.getItem("carrito"))||[];
let categoriasBase=JSON.parse(localStorage.getItem("categoriasBase"))||[
{nombre:"BLOOMSHELL",img:"https://via.placeholder.com/150"},
{nombre:"ATENEA",img:"https://via.placeholder.com/150"},
{nombre:"ANI-K",img:"https://via.placeholder.com/150"},
{nombre:"MONTOC",img:"https://via.placeholder.com/150"}
];

// --- SUBIR IMAGENES ---
function subirImagen(){
const widget = cloudinary.createUploadWidget({
cloudName: cloudName,
uploadPreset: uploadPreset,
sources:["local","url","camera"],
multiple:false,
resourceType:"image"
}, (error, result)=>{
if(!error && result && result.event==="success"){
imagenTemporal=result.info.secure_url;
alert("Imagen subida correctamente");
}});
widget.open();
}

function subirImagenCategoria(){
const widget = cloudinary.createUploadWidget({
cloudName: cloudName,
uploadPreset: uploadPreset,
sources:["local","url","camera"],
multiple:false,
resourceType:"image"
}, (error, result)=>{
if(!error && result && result.event==="success"){
imagenCategoriaTemporal=result.info.secure_url;
alert("Imagen de categoría subida correctamente");
}});
widget.open();
}

// --- AGREGAR CATEGORIA ---
function agregarCategoria(){
let nombre=document.getElementById("nuevaCategoriaNombre").value;
if(!nombre || !imagenCategoriaTemporal){
alert("Completa nombre y sube imagen");
return;
}
categoriasBase.push({nombre:nombre,img:imagenCategoriaTemporal});
localStorage.setItem("categoriasBase",JSON.stringify(categoriasBase));
imagenCategoriaTemporal="";
document.getElementById("nuevaCategoriaNombre").value="";
cargarCategorias();
actualizarAdminCategorias();
alert("Categoría agregada correctamente");
}

// --- AGREGAR PRODUCTO ---
function guardarProducto(){
let nombre=document.getElementById("nombreProducto").value;
let categoria=document.getElementById("categoriaProducto").value;
if(!imagenTemporal){alert("Sube una imagen");return;}
productos.push({nombre,imagenes:[imagenTemporal],categoria});
localStorage.setItem("productos",JSON.stringify(productos));
imagenTemporal="";
actualizarAdmin();
}

// --- ADMIN CATEGORIAS ---
function actualizarAdminCategorias(){
let lista=document.getElementById("listaAdminCategorias");
lista.innerHTML="";
categoriasBase.forEach((cat,i)=>{
    lista.innerHTML+=`
    <div class="admin-product">
        <input type="text" value="${cat.nombre}" id="catNombre${i}">
        <p>Imagen actual:</p>
        <img src="${cat.img}" style="width:60px;height:60px;border-radius:8px;object-fit:cover;margin-bottom:5px;">
        <button onclick="editarImagenCategoriaPortada(${i})">Subir Portada</button>
        <button onclick="guardarCategoriaEditada(${i})">Guardar</button>
        <button onclick="eliminarCategoria(${i})">Eliminar</button>
    </div>`;
});
}

function editarImagenCategoriaPortada(index){
const widget = cloudinary.createUploadWidget({
cloudName: cloudName,
uploadPreset: uploadPreset,
sources:["local","url","camera"],
multiple:false,
resourceType:"image"
}, (error, result)=>{
if(!error && result && result.event==="success"){
categoriasBase[index].portada = result.info.secure_url;
localStorage.setItem("categoriasBase",JSON.stringify(categoriasBase));
actualizarAdminCategorias();
cargarCategorias();
alert("Portada de categoría actualizada correctamente");
}});
widget.open();
}

function guardarCategoriaEditada(index){
let nuevoNombre=document.getElementById("catNombre"+index).value;
if(!nuevoNombre){
alert("El nombre no puede estar vacío");
return;
}
categoriasBase[index].nombre=nuevoNombre;
localStorage.setItem("categoriasBase",JSON.stringify(categoriasBase));
actualizarAdminCategorias();
cargarCategorias();
alert("Categoría editada correctamente");
}

function eliminarCategoria(index){
if(confirm("¿Eliminar esta categoría?")){
categoriasBase.splice(index,1);
localStorage.setItem("categoriasBase",JSON.stringify(categoriasBase));
actualizarAdminCategorias();
cargarCategorias();
}
}

// --- ADMIN PRODUCTOS ---
function actualizarAdmin(){
let lista=document.getElementById("listaAdminProductos");
lista.innerHTML="";
productos.forEach((p,i)=>{
lista.innerHTML+=`
<div class="admin-product">
<input type="text" value="${p.nombre}" id="prodNombre${i}">
<select id="prodCategoria${i}"></select>
<button onclick="editarImagenProducto(${i})">Cambiar Imagen</button>
<button onclick="guardarProductoEditado(${i})">Guardar</button>
<button onclick="eliminarProducto(${i})">Eliminar</button>
</div>`;
});

// Llenar selects de categoría
productos.forEach((p,i)=>{
let select=document.getElementById("prodCategoria"+i);
select.innerHTML="";
categoriasBase.forEach(cat=>{
select.innerHTML+=`<option value="${cat.nombre}" ${cat.nombre===p.categoria?'selected':''}>${cat.nombre}</option>`;
});
});
}

function editarImagenProducto(index){
const widget = cloudinary.createUploadWidget({
cloudName: cloudName,
uploadPreset: uploadPreset,
sources:["local","url","camera"],
multiple:false,
resourceType:"image"
}, (error, result)=>{
if(!error && result && result.event==="success"){
productos[index].imagenes=[result.info.secure_url];
localStorage.setItem("productos",JSON.stringify(productos));
actualizarAdmin();
mostrarProductos(productos[index].categoria);
alert("Imagen del producto actualizada");
}});
widget.open();
}

function guardarProductoEditado(index){
let nuevoNombre=document.getElementById("prodNombre"+index).value;
let nuevaCategoria=document.getElementById("prodCategoria"+index).value;
if(!nuevoNombre || !nuevaCategoria){
alert("Completa todos los campos");
return;
}
productos[index].nombre=nuevoNombre;
productos[index].categoria=nuevaCategoria;
localStorage.setItem("productos",JSON.stringify(productos));
actualizarAdmin();
mostrarProductos(nuevaCategoria);
alert("Producto editado correctamente");
}

function eliminarProducto(i){
productos.splice(i,1);
localStorage.setItem("productos",JSON.stringify(productos));
actualizarAdmin();
}

// --- ACCESO ADMIN ---
document.addEventListener("keydown",function(e){
if(e.ctrlKey && e.shiftKey && e.key==="A"){
let pass=prompt("Contraseña:");
if(pass==="sofi16"){
document.getElementById("adminPanel").classList.add("active");
actualizarAdmin();
actualizarAdminCategorias();
}
}
});

function cerrarAdmin(){
document.getElementById("adminPanel").classList.remove("active");
}

// --- CATEGORIAS FRONT ---
function cargarCategorias(){
let cont=document.getElementById("categorias");
let select=document.getElementById("categoriaProducto");
cont.innerHTML="";
select.innerHTML="";
categoriasBase.forEach(cat=>{
let imgUrl = cat.portada || cat.img; // usa portada si existe
cont.innerHTML+=`
<div class="categoria" onclick="mostrarProductos('${cat.nombre}')">
<img src="${imgUrl}">
<p>${cat.nombre}</p>
</div>`;
select.innerHTML+=`<option value="${cat.nombre}">${cat.nombre}</option>`;
});
}

function mostrarProductos(cat){
let cont=document.getElementById("productos");
cont.innerHTML="";
productos.filter(p=>p.categoria===cat)
.forEach(p=>cont.innerHTML+=productoHTML(p));
}

function productoHTML(p){
return `
<div class="producto">
${(p.imagenes||[]).map(img=>`<img src="${img}">`).join("")}
<h4>${p.nombre}</h4>
<button onclick="agregarCarrito('${p.nombre}')">Agregar al carrito</button>
</div>`;
}

// --- CARRITO ---
function agregarCarrito(nombre){
let index=carrito.findIndex(p=>p.nombre===nombre);
if(index===-1){carrito.push({nombre});}
else{carrito.splice(index,1);}
localStorage.setItem("carrito",JSON.stringify(carrito));
actualizarContador();
}

function actualizarContador(){
document.getElementById("contador").innerText=carrito.length;
}

function abrirCarrito(){
let lista=document.getElementById("listaCarrito");
lista.innerHTML="";
carrito.forEach((p,i)=>{
lista.innerHTML+=`<p>${p.nombre}<button onclick="eliminarDelCarrito(${i})">❌</button></p>`;
});
document.getElementById("carritoModal").style.display="block";
}

function eliminarDelCarrito(i){
carrito.splice(i,1);
localStorage.setItem("carrito",JSON.stringify(carrito));
actualizarContador();
abrirCarrito();
}

function cerrarCarrito(){
document.getElementById("carritoModal").style.display="none";
}

function enviarWhatsApp(){
let mensaje="Hola quiero pedir:%0A";
carrito.forEach(p=>mensaje+="• "+p.nombre+"%0A");
window.open("https://wa.me/573105708787?text="+mensaje);
}

// --- BUSCADOR ---
function toggleBuscador(){
let input=document.getElementById("buscadorInput");
input.style.display=input.style.display==="block"?"none":"block";
}

function buscarProductos(){
let texto=document.getElementById("buscadorInput").value.toLowerCase();
let cont=document.getElementById("productos");
cont.innerHTML="";
productos.filter(p=>p.nombre.toLowerCase().includes(texto))
.forEach(p=>cont.innerHTML+=productoHTML(p));
}

cargarCategorias();
actualizarContador();

</script>
</body>
</html>